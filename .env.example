# orbit_console_nextjs tests — copy to .env

# URL of the running console (local or staging)
CONSOLE_URL=http://localhost:3000

# Supabase (for API tests + user management)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Test user (must exist and be approved in Supabase auth.users + profiles)
TEST_USER_EMAIL=testuser@orbit-test.local
TEST_USER_PASSWORD=TestPass123!

# Admin user (profiles.role = 'admin', approved)
ADMIN_USER_EMAIL=admin@quantumdice.io
ADMIN_USER_PASSWORD=AdminPass123!

# Organization ID for org-scoped tests (optional)
TEST_ORGANIZATION_ID=
